{
    // Utilisez IntelliSense pour en savoir plus sur les attributs possibles.
    // Pointez pour afficher la description des attributs existants.
    // Pour plus d'informations, visitez : https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Main",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/runner/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "HABMOTI_DEVICE_TYPE": "<DEVICE_TO_USE>", // Options: "zed", "mocked_zed" 
                "HABMOTI_ZED_PARAMETERS": "{\"configuration_filepath\": \"<PATH_TO_CONFIG_FILE>\"}", // Ignored if HABMOTI_DEVICE_TYPE =/= "zed"
                "HABMOTI_MOCKED_ZED_PARAMETERS": "{\"target_fps\": <FPS_TO_SIMULATE_AS_INT>, \"max_fps_lag_ms\": <VARABILITY_TO_SIMULATE_AS_INT>}", // Ignored if HABMOTI_DEVICE_TYPE =/= "mocked_zed"
                "HABMOTI_ANALYZERS": "[\"<LIST_OF_ANALYZERS>\", \"<COMMA_SEPARATED>\"]", // Options: "to_console", "to_csv"
                "HABMOTI_TO_CONSOLE_ANALYZER_PARAMETERS": "{\"joint_center\": \"<DOF_TO_PRINT>\"}", // Options depends on the model used (e.g. of valid value: NOSE). Ignored if "to_console" not in "HABMOTI_ANALYZERS"
                "HABMOTI_TO_CSV_ANALYZER_PARAMETERS": "{\"filepath\": \"PATH_TO_OUTPUT_FILE\"}", // Ignored if "to_csv" not in "HABMOTI_ANALYZERS"
            },
            "cwd": "${workspaceFolder}/runner/"
        },
    ]
}